%% ============================================================
%% L1-b · 模块地图 —— 这张图回答:「代码分成哪几大块,谁依赖谁」
%% 受众: 有基础知识的非开发者也要能读懂(人话为主) + 开发者可定位(括号内目录名)
%% 依赖纪律: 箭头=依赖方向,只许朝下游流;协作层曾反向依赖接口层,已修复
%% 基于 commit: 9ac565e (2026-07-03)
%% ============================================================
flowchart LR

  subgraph FRONT["页面(frontend/ · Next.js)"]
    FCOMP["界面组件:方案卡/时间轴/聊天/房间<br/>(components/)"]
    FSTORE["页面状态与发请求<br/>(lib/store.ts + collab-store.ts)"]
    FEVT["接收实时推送并更新页面<br/>(lib/store/event-handlers.ts)"]
    FTYPES["前后端数据格式的对照表<br/>手抄自后端,有同步纪律<br/>(lib/types.ts)"]
  end

  subgraph API["接口层(backend/api/ · 9 组路由 18 个接口)"]
    ACHAT["对话/确认/换菜三个核心接口<br/>(chat.py + adjust.py)"]
    ACOLLAB["房间接口+实时通道<br/>(collab.py)"]
    ASTREAMS["流式推送的具体实现<br/>(_streams/)"]
    ASESS["会话速查缓存<br/>(_session_store.py)"]
    AMISC["场景/健康检查/偏好/地图代理等<br/>(scenarios, health, preferences…)"]
  end

  subgraph GRAPHM["大脑编排层(backend/agent/graph/)"]
    GBUILD["流程拓扑的唯一定义处<br/>(build.py)"]
    GNODES["流程上的各个工位<br/>分诊/抽取/规划/质检/叙事…(nodes/)"]
    GSSE["工位产出→实时事件的翻译器<br/>(sse_adapter + _emit_handlers)"]
    GSTATE["对话记忆的字段清单与生命周期<br/>(state.py)"]
    GRES["出错时的逐级降级安全网<br/>(_resilience.py)"]
  end

  subgraph BRAIN["理解层(backend/agent/ 下的认知模块)"]
    RROUTE["分诊:判断一句话想干嘛<br/>(routing/ · 正在重写)"]
    RINTENT["读需求/合并意见/写讲解<br/>(intent/)"]
    RCTX["上下文打包器:整理对话史给 AI<br/>(context/)"]
    RCORE["AI 通道/安全防护/软约束嗅探<br/>(core/)"]
  end

  subgraph PLAN["求解层(backend/agent/planning/)"]
    PBLUE["AI 起草行程蓝图+拼装<br/>(blueprint/)"]
    PPLAN["算法引擎:备用重排/换菜引擎<br/>(planners/)"]
    PCRIT["质检规则 13 条+诚实告知<br/>(critic/)"]
    PCOMM["路程估算/偏好权重/节奏留白<br/>(commute/ 等)"]
  end

  COLLAB["协作房间管家<br/>记名发言/排队调整/自动销毁<br/>(backend/collab/room.py)"]
  SCHEMAS["数据格式契约:所有结构的唯一定义<br/>(backend/schemas/)"]
  DATA["演示数据与工具<br/>景点/餐厅/路程 + 9 个受控查询工具<br/>(backend/data/ + tools/ + mock_data/)"]

  FCOMP --> FSTORE --> FEVT
  FSTORE -->|"HTTP 请求 / WebSocket"| API
  FTYPES -.->|"手抄同步纪律"| SCHEMAS

  ACHAT --> ASTREAMS --> GRAPHM
  ACOLLAB --> COLLAB
  API --> ASESS
  COLLAB --> RROUTE
  COLLAB --> PPLAN
  GNODES --> RROUTE & RINTENT & RCTX
  GNODES --> PBLUE & PPLAN & PCRIT
  RROUTE --> RCORE
  RINTENT --> RCORE
  RCTX --> SCHEMAS
  PLAN --> DATA
  BRAIN --> SCHEMAS
  GRAPHM --> SCHEMAS
  DATA --> SCHEMAS
