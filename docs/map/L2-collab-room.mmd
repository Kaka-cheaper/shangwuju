%% ----
%% 下行 11 类(快照类 1 + 广播类 10,均由 BCAST 发出,前端 switch 逐一处理):
%%   room_state / member_joined / member_reconnected / member_left / constraint_added /
%%   vote_updated / node_locked / node_unlocked / planning_started / planning_aborted / planning_event
%%   (planning_event 内层再套 chitchat_reply/itinerary_ready/agent_narration/refinement_done/
%%    intent_parsed/stream_error/done 等——同 L1 的 SSE 事件族,复用同一份事件形状)
%%   不计入 11 类:"error"(api/collab.py:171,207,215,226,room.py:800-806——单发给违规者,非广播)
%%   与"pong"(api/collab.py:236——纯协议保活,无业务语义)。
%%   前端 collab-store.ts 里还有一个 "confirmed" case(第 445-451 行)——排查后端未见任何
%%   `broadcast(...{"type": "confirmed"...})` 调用点,疑似历史遗留的死分支(confirm 结果实际是
%%   通过 planning_event:itinerary_ready 到达前端的),不计入 11 类,已列入报告的"不确定"清单。
%% ============================================================
flowchart TB

  subgraph FE["前端页面(frontend/app/room · frontend/lib/collab-store.ts)"]
    ENTRY["进房:填昵称,或直接用邀请链接自带的昵称<br/>(RoomClient · NicknameEntryCard)"]
    CRED["重连凭证:本地记住的临时身份,刷新页面也认得<br/>(localStorage collab_user_id)"]
    JOINCALL["发起连接<br/>(joinRoom → createWsClient)"]
    ACT["打字 / 点赞踩 / 点节点调整按钮 / 点确认并预约<br/>(sendConstraint / sendVote / sendAdjust / sendConfirm)"]
    RECV["收到下行消息,更新页面<br/>(handleWsMessage → 主 store / collab store)"]
  end

  subgraph WSAPI["WebSocket 入口(backend/api/collab.py)"]
    ACCEPT["建立连接,读身份参数<br/>(ws_collab · accept + query_params)"]
    DISPATCH["上行 5 类消息分发<br/>(constraint / vote / adjust / confirm / ping)"]
  end

  subgraph MGR["房间管家(backend/collab/room.py · RoomManager)"]
    JOIN["加入房间:首次广播member_joined,重连广播member_reconnected;<br/>两分支都先给入房者本人推一份 room_state 快照(含 confirmed 守门标记 + node_actions——中途加入者现在也能立刻看到调整按钮,评委体验修复)<br/>(RoomManager.join → get_state_snapshot)"]
    ADDC["自由打字入口:先无条件归名广播,再判义务分发<br/>(RoomManager.add_constraint)"]
    VOTE["投票:赞记锁定,踩收编成节点级局部调整<br/>(RoomManager.update_vote)"]
    ADJ["节点调整:串行队列 + 处理期锁定广播<br/>(RoomManager.adjust)"]
    CONF["房主确认:复用单人确认流<br/>(RoomManager.confirm)"]
    BCAST["广播器:发给全员,或单发给某一人<br/>(broadcast / _send / _broadcast_planning_event)"]
  end

  subgraph ROUTE["统一分诊台(backend/agent/routing/route_turn.py)"]
    RTURN["判断这句话该负什么义务(六标签)<br/>planning / feedback / chitchat / confirm / clarify / defense<br/>(route_turn)"]
    CHATBUB["气泡广播:不动方案,不碰约束池,不打断在跑规划<br/>(chitchat_reply 事件)"]
  end

  subgraph REPLAN["房间触发重新规划(与 L1 大脑主流程的接口)"]
    TRIG_R["义务=feedback:追加进约束池,中断在跑规划,合并重排<br/>(_trigger_replan → _run_planning)"]
    TRIG_F["义务=planning:不进约束池不经refiner,整句独立请求直接重开一局<br/>(_trigger_fresh_plan → _plan_fresh)"]
  end

  subgraph SWAP["换菜引擎(复用单人 F-4 同一套引擎)"]
    RESOLVE["候选池现场重查 + 局部重解,成败都不让异常冒泡<br/>(_resolve_and_broadcast_adjust → resolve_node_swap)"]
  end

  subgraph SCONF["单人确认流(复用,不新起分支)"]
    GCONF["读会话缓存,执行下单/订座/买票<br/>(_graph_confirm → execute_finalize)"]
  end

  ENTRY -->|"读/写"| CRED
  ENTRY --> JOINCALL
  CRED --> JOINCALL
  JOINCALL -->|"WS /ws/room_id?user_id&nickname"| ACCEPT
  ACCEPT --> JOIN
  ACT -->|"上行 JSON"| DISPATCH

  DISPATCH -->|"constraint"| ADDC
  DISPATCH -->|"vote"| VOTE
  DISPATCH -->|"adjust(节点行按钮/具名备选)"| ADJ
  DISPATCH -->|"confirm(仅房主,否则单发error)"| CONF

  ADDC --> RTURN
  RTURN -->|"feedback"| TRIG_R
  RTURN -->|"planning"| TRIG_F
  RTURN -->|"chitchat / confirm / clarify / defense"| CHATBUB

  VOTE -->|"dislike收编"| ADJ
  ADJ --> RESOLVE
  CONF --> GCONF

  JOIN --> BCAST
  ADDC -->|"归名广播,与义务判定无关"| BCAST
  VOTE -->|"vote_updated"| BCAST
  ADJ -->|"node_locked → ... → node_unlocked"| BCAST
  CHATBUB --> BCAST
  TRIG_R -->|"planning_started/planning_aborted + 规划事件"| BCAST
  TRIG_F -->|"planning_started/planning_aborted + 规划事件"| BCAST
  RESOLVE -->|"成功→itinerary_ready+agent_narration;失败→只广播告知气泡"| BCAST
  GCONF -->|"逐条转发确认阶段事件"| BCAST

  BCAST -->|"下行11类:room_state / member_joined / member_reconnected / member_left / constraint_added / vote_updated / node_locked / node_unlocked / planning_started / planning_aborted / planning_event"| RECV
