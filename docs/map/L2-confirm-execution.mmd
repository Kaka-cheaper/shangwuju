%% L2-b · 确认下单执行链 —— 这张图回答:「点确认之后发生什么」
%% 受众: 有基础知识的非开发者也要能读懂(人话为主) + 开发者可定位(括号内代码名)
%% 文字纪律: 每框第一行人话职责,括号内是代码里的名字;分支走多条命名边,不用菱形节点
%%   (与 L1 系列同一约定);虚线=后台任务(不阻塞主流程/不阻塞DONE)
%% 基于 commit: 57afcef · 读码材料: api/_streams/graph_confirm.py、
%%   agent/graph/nodes/execute_finalize.py、api/_streams/memory.py、
%%   agent/planning/memory_writer.py(按名引用,未逐行读)、api/chat.py
%% ----
%% 【锚点表】
%%   端点定义                api/chat.py:29-62(chat_confirm,恒走 _graph_confirm)
%%   守门1-非confirm决策      api/_streams/graph_confirm.py:67-73
%%   缓存读取                 api/_streams/graph_confirm.py:75-77
%%   守门2-session/itinerary缺失 api/_streams/graph_confirm.py:77-86(STREAM_ERROR session_not_found)
%%   守门3-反序列化失败        api/_streams/graph_confirm.py:88-101(STREAM_ERROR invalid_session_snapshot)
%%   后台执行+心跳             api/_streams/graph_confirm.py:103-146(asyncio.wait_for+shield,1.5s心跳;CancelledError/Exception分支)
%%   pending_actions优先/现算  agent/graph/nodes/execute_finalize.py:116-125
%%   4类订单工具-餐厅预约       agent/graph/nodes/execute_finalize.py:55-68,181-196(reserve_restaurant)
%%   4类订单工具-门票           agent/graph/nodes/execute_finalize.py:70-78,197-209(buy_ticket)
%%   4类订单工具-附加服务       agent/graph/nodes/execute_finalize.py:80-99,210-227(order_extra_service,intent缺省则跳过)
%%   4类订单工具-转发文案       agent/graph/nodes/execute_finalize.py:101-112,228-231(generate_share_message,永远生成)
%%   replay主循环              agent/graph/nodes/execute_finalize.py:158-233(replay_confirm_actions)
%%   confirm阶段narration      agent/graph/nodes/execute_finalize.py:129-135,287-304(defer=True时use_llm=False,恒规则模板)
%%   defer_post_confirm_effects语义 agent/graph/nodes/execute_finalize.py:130,150-153;api/_streams/graph_confirm.py:111(finalize_state固定传True)
%%   tool_call事件回放          api/_streams/graph_confirm.py:148-163
%%   SESSION_STORE整体替换      api/_streams/graph_confirm.py:174
%%   ITINERARY_READY            api/_streams/graph_confirm.py:175
%%   后台-memory_store标签累积  api/_streams/graph_confirm.py:181-184,258-287;api/_streams/memory.py:66-135(_accumulate_memory_after_confirm,无条件调用)
%%   后台-memory_writer偏好回写 api/_streams/graph_confirm.py:186-192,213-256(_persist_memory_side_effect,条件:post_confirm_effects_deferred且intent非None)
%%   同步回写图状态(必须在DONE前) api/_streams/graph_confirm.py:194-199,290-368(_writeback_graph_state)
%%   版本志追加(trigger=confirm)  api/_streams/graph_confirm.py:338-345
%%   aupdate_state写itinerary+user_decision api/_streams/graph_confirm.py:347-355(as_node="narrate")
%%   降级1-无图checkpoint         api/_streams/graph_confirm.py:329-336(info日志,静默跳过,不影响确认结果)
%%   降级2-回写异常                api/_streams/graph_confirm.py:363-368(warning日志,静默跳过)
%%   narration SSE                api/_streams/graph_confirm.py:201-205
%%   memory_status SSE            api/_streams/graph_confirm.py:207-208(见下方"我不确定"标注)
%%   DONE收尾                     api/_streams/graph_confirm.py:210
%% ============================================================
flowchart TB

  ENTRY["用户点「确认并预约」<br/>(POST /chat/confirm → _graph_confirm)"]

  ENTRY --> GATE1["守门①:这是不是真的confirm<br/>(decision字段)"]
  GATE1 -->|"reject/modify → 只告知不执行,不算失败"| EARLYOUT["回一句「已收到,本次不执行预约」<br/>直接收尾"]
  EARLYOUT --> DONE1["DONE"]

  GATE1 -->|"confirm → 继续"| READCACHE["读会话速查缓存拿方案快照<br/>(SESSION_STORE.get)"]
  READCACHE --> GATE2["守门②:快照存在且含itinerary吗"]
  GATE2 -->|"缺失(session过期/从没规划过)"| ERR1["STREAM_ERROR:session_not_found"]
  ERR1 --> DONEERR1["DONE"]

  GATE2 -->|"存在 → 继续"| GATE3["守门③:intent/itinerary能还原成模型吗<br/>(Pydantic model_validate)"]
  GATE3 -->|"反序列化失败(脏快照)"| ERR2["STREAM_ERROR:invalid_session_snapshot"]
  ERR2 --> DONEERR2["DONE"]

  GATE3 -->|"还原成功"| THOUGHT["先发一句『正在确认预约与加购服务』<br/>(AGENT_THOUGHT)"]
  THOUGHT --> RUNBG["后台线程跑确认执行,主协程带心跳等待<br/>(asyncio.wait_for + shield,1.5s一拍)"]

  RUNBG -->|"超时未完成(心跳)"| HEARTBEAT["再发一句『还在处理』<br/>(AGENT_THOUGHT,自环继续等)"]
  HEARTBEAT --> RUNBG
  RUNBG -->|"客户端断连(CancelledError)"| CANCELPATH["取消后台任务,向上抛异常<br/>(不产出更多SSE,连接已断)"]
  RUNBG -->|"执行抛出未预期异常"| ERR3["STREAM_ERROR:finalize_failed"]
  ERR3 --> DONEERR3["DONE"]

  RUNBG -->|"正常完成"| EXECRESULT["拿到执行结果<br/>(orders/execution_tool_results/share_message/narration)"]

  subgraph EXEC["确认执行:execute_finalize_node —— 4类订单工具"]
    PLANACT["清单来源:优先用规划期已算好的清单<br/>没有才现算(兼容旧方案)<br/>(pending_actions / build_confirm_actions)"]
    REPLAY["逐条replay,不重新决策<br/>(replay_confirm_actions)"]
    T1["订餐厅位<br/>(reserve_restaurant · 每个用餐节点一次)"]
    T2["买门票<br/>(buy_ticket · 每个POI节点一次)"]
    T3["加购附加服务<br/>(order_extra_service · 按intent.extra_services,intent缺省则跳过)"]
    T4["生成转发文案<br/>(generate_share_message · 永远生成)"]
    NARRGEN["confirm阶段说明文案<br/>(规则模板,不调LLM——因下方defer标记恒为真)"]
  end

  THOUGHT -.-> PLANACT
  PLANACT --> REPLAY
  REPLAY --> T1 & T2 & T3 & T4
  T1 & T2 & T3 & T4 --> NARRGEN
  NARRGEN --> EXECRESULT

  EXECRESULT --> TOOLEVT["逐条工具结果配对发送<br/>(TOOL_CALL_START → TOOL_CALL_END)"]
  TOOLEVT --> HASITIN["方案里有终版itinerary吗"]

  HASITIN -->|"有(正常情况,前面守门已保证)"| WRITECACHE["整体替换会话速查缓存<br/>(SESSION_STORE[sid]=既有快照+itinerary新值)"]
  WRITECACHE --> ITINRDY["推方案给前端<br/>(ITINERARY_READY)"]

  ITINRDY -.->|"后台任务,不阻塞DONE"| MEMTAG["memory_store标签/访问累积<br/>(_accumulate_memory_after_confirm · 无条件调用)"]
  MEMTAG -.-> USERMEM["写入UserMemory<br/>(persona_qa/intent_parser先验/排重/preferences API 的真实读者)"]

  ITINRDY -.->|"后台任务,仅当intent非None,不阻塞DONE"| MEMWRITE["memory_writer偏好回写<br/>(_persist_memory_side_effect)"]
  MEMWRITE -.-> USERPROFILE["写入user_profile.json的recent_trips"]

  ITINRDY -->|"必须在DONE前同步await完"| WBSTART["回写图状态开始<br/>(_writeback_graph_state)"]
  WBSTART --> WBCHECK["图里有这个session的checkpoint吗<br/>(aget_state)"]
  WBCHECK -->|"没有(协作房间会话/从没跑过图)"| WBSKIP["记info日志,静默跳过<br/>不影响确认结果本身"]
  WBCHECK -->|"有"| WBAPPEND["组装版本志新条目<br/>(trigger=confirm,summary=已确认下单)"]
  WBAPPEND --> WBWRITE["一次aupdate_state写三件事<br/>itinerary + user_decision=confirm + plan_version_log<br/>(as_node=narrate)"]
  WBWRITE -->|"写入异常(如redis抖动)"| WBFAIL["记warning日志,静默跳过<br/>不影响确认结果本身"]
  WBWRITE -->|"成功"| WBOK["图状态回写成功"]

  WBSKIP --> AFTERWB["继续收尾"]
  WBFAIL --> AFTERWB
  WBOK --> AFTERWB

  AFTERWB --> HASNARR["result里有narration吗"]
  HASNARR -->|"有(NARRGEN规则模板产出的文案)"| NARREVT["推确认阶段说明文案<br/>(AGENT_NARRATION,stage=confirm)"]
  HASNARR -->|"无"| SKIPNARR["跳过"]
  NARREVT --> HASMEM
  SKIPNARR --> HASMEM

  HASMEM["result里有memory_status吗"]
  HASMEM -->|"有 → 推MEMORY_PERSISTED"| MEMEVT["推记忆回写状态<br/>(MEMORY_PERSISTED)"]
  HASMEM -->|"无(见下方我不确定标注)"| SKIPMEM["跳过"]
  MEMEVT --> FINALDONE
  SKIPMEM --> FINALDONE

  HASITIN -->|"理论上不该发生(前面守门已保证有itinerary)"| SKIPALL["跳过缓存写入/后续所有事件,直接收尾"]
  SKIPALL --> FINALDONE

  FINALDONE["DONE"]

  UNSURE["我不确定:defer_post_confirm_effects在本流程恒为True<br/>execute_finalize_node因此永远走「延后」分支<br/>从不在result里同步写memory_status——<br/>HASMEM这条「有」分支在当前confirm流程里<br/>是否已是永远不可达的死代码,需要作者确认"]
  HASMEM -.-> UNSURE
