flowchart TB

  TURNEP["用户发一轮消息,驱动图跑一次<br/>(POST /chat/turn → chat.py::chat_turn)"]

  subgraph TRUTH["跨轮记忆的真相源(单人会话):图状态存档"]
    CKPT["图状态存档:整场对话的唯一真相源<br/>键=thread_id=session_id<br/>(checkpointer · InMemorySaver/AsyncRedisSaver 双模)"]
    MSGLOG["轮次日志:谁在哪一轮说了什么<br/>(state.messages · add_messages 累积)"]
    VERLOG["方案版本志:方案怎么一步步演化成这版<br/>(state.plan_version_log · operator.add 累积)"]
    LEDGER["诉求台账:谁提过什么要求,满足了没有<br/>(state.demand_ledger · 自定义归并器)"]
    OTHER["其余按轮/按规划事件生灭的工作字段<br/>意图/方案/critic状态/确认态等<br/>(TURN_SCOPED + EPISODE_SCOPED,详见 L3 生命周期图)"]
  end

  TURNEP -->|"graph.astream(初始diff, config=thread_id)"| CKPT

  %% ---- 三器官的写手 ----
  ROUTERN["分诊节点每轮无条件写一条用户发言<br/>(router_node)"] -->|"HumanMessage(必要时补AIMessage)"| MSGLOG
  NARRN["写讲解节点写一条agent侧发言<br/>(narrate_node,仅规划/反馈轮)"] -->|"AIMessage"| MSGLOG

  FINALN["定稿节点:方案定稿即新版本诞生<br/>(finalize_plan_node · trigger=first/feedback)"] -->|"追加一条"| VERLOG
  ADJN["换菜端点:换菜也是新版本<br/>(_graph_adjust · trigger=adjust)"] -->|"aupdate_state 追加一条"| VERLOG
  CONFN["确认端点:回写终版方案时顺手追加<br/>(_writeback_graph_state · trigger=confirm)"] -->|"aupdate_state 追加一条"| VERLOG
  CONFN -->|"同一次aupdate_state:itinerary+user_decision=confirm"| OTHER
  ADJN -->|"同一次aupdate_state:itinerary+node_actions+advisories"| OTHER

  LEDGERW["换菜端点:记账,命中方向诉求且真满足则标满足<br/>(record_demand / mark_satisfied)"] -->|"aupdate_state 整体替换(归并器保证空更新=保留旧值)"| LEDGER

  %% ---- 台账被谁读 ----
  LEDGER -->|"直接读(不经打包器):取生效诉求供本次换菜引擎参考"| LEDGERW

  %% ---- 上下文打包器 ----
  subgraph PACKBOX["上下文打包器(agent/context/) —— 三器官+方案+画像的统一整理站"]
    SRC["底座协议:把不同来源翻译成同一形状<br/>(SessionContextSource)"]
    PACK["打包器:整理成一份AI能读的会话摘要<br/>(pack_routing_context · 纯函数,不做I/O,不调LLM)"]
  end

  MSGLOG -.->|"turn_log()"| SRC
  VERLOG -.->|"plan_version_log()"| SRC
  LEDGER -.->|"demand_ledger_raw()"| SRC
  OTHER -.->|"current_itinerary_dict()/user_decision()/画像字段"| SRC
  SRC --> PACK

  PACK -->|"render_text():仅真要调LLM判断这句话时才打包"| ROUTERBRAIN["路由脑子的一次LLM判断<br/>(agent/routing/route_turn.py · 脑子层)"]
  PACK -->|"render_demand_recap():版本志+台账生效切片"| REFN["反馈合并节点<br/>(refiner_node)"]
  PACK -->|"plan_version_log 切片→反馈回顾句"| NARRN2["写讲解节点的反馈回顾句<br/>(narrate_node · _plan_recap_clause)"]

  %% ---- 协作房间:另一个底座,另一个真相源 ----
  ROOMTRUTH["协作房间会话的真相源:Room对象本身<br/>没有图checkpoint<br/>(collab.room.Room)"]
  ROOMSRC["房间版底座:同一协议的另一份实现<br/>(RoomSource)"]
  ROOMTRUTH -->|"chat_messages/demand_ledger/current_itinerary_dict"| ROOMSRC
  ROOMSRC -->|"同一协议,打包器对来源无感;房间自由打字已实接<br/>(room.py add_constraint 传 RoomSource)"| SRC

  %% ---- 会话速查缓存:投影,不是真相源 ----
  subgraph CACHEBOX["会话速查缓存(api/_session_store.py) —— 只为HTTP层快速取「当前方案」"]
    CACHE["投影字典:session_id → 当前方案快照<br/>不读图状态,自己是独立的内存字典<br/>(SESSION_STORE)"]
  end

  CKPT -->|"节点输出汇成SSE事件流"| SYNCPOINT["拦截 ITINERARY_READY 事件<br/>(_graph_stream_with_session_sync)"]
  SYNCPOINT -->|"整体重建4键:intent/itinerary/user_id/planning_events"| CACHE
  ADJN -->|"局部patch:只覆盖itinerary键,其余键沿用既有快照<br/>(sync_snapshot 合并入口)"| CACHE
  CONFN3["确认端点主流程:预约执行完成后<br/>(_graph_confirm)"] -->|"整体替换:既有快照+itinerary新值"| CACHE

  CACHE -->|"取intent+itinerary起跑执行"| CONFSTART["确认端点入口读取<br/>(_graph_confirm 开头两道守门)"]
  CONFSTART -.->|"执行完成后"| CONFN3
  CONFN3 -.->|"执行完成后同步回写"| CONFN
  CACHE -->|"建房时取当前方案做初始种子"| ROOMCREATE["建房接口<br/>(POST /room/create)"]

  %% ---- 提醒:两套Redis互不相干 ----
  NOTE1["提醒:CACHE的Redis镜像(SESSION_STORE)与CKPT的AsyncRedisSaver<br/>是两套独立机制,各自按环境变量启用,互不感知,互不同步"]
  CACHE -.-> NOTE1
  CKPT -.-> NOTE1
