%% ============================================================
%% 读代码核实后的三处「常见描述 vs 实际代码」落差(读码实证,非猜测):
%% ------------------------------------------------------------
%%   1) ILS 内部早已不是「候选池→构造→迭代局部搜索→修复闭环」里的「迭代局部搜索」——
%%      ADR-0010 的诊断是旧扰动+局部搜索在新搜索空间下 provably inert(150 次迭代
%%      0 次找到更优解),已整段删除,换成「贪心插入构造」(锚点段+涌现段一次到位)
%%      + 「min-conflicts 式有界修复」。本图按实际代码画,ILS_BUILD 不含局部搜索环节。
%%   2) agent/graph/build.py 的 _route_after_ils 函数体硬编码 return "finalize_plan",
%%      不看 state——即使 add_conditional_edges 的 path_map 里还留着一条
%%      {"critic": "critic"} 的映射,这条分支永远不会被走到。本图 ILS 之后一律
%%      直奔定稿,不画回质检的边。
%%   3) replan_router_node 的「重试计数超过上限(默认 4)→ give_up」分支在当前接线下
%%      基本不可达:ILS 一旦被触发(第 3 次重试),不论成不成功都经 _route_after_ils
%%      直接终结本轮(见 2),不会再回到 replan_router 把计数累加到 5。该分支的注释
%%      原话自认是「万一未来重新接回 critic」的防线,不是当前会走到的路。本图仍画出
%%      这条边(代码确实存在这个分支),但如实标注其当前接线下罕见触达。
%% ============================================================

flowchart TB

  subgraph L1IN["承接 L1:候选已备好"]
    IN0["三路查询已汇合,候选池就绪<br/>(execute_collect,详见 L1 全景图)"]
  end

  subgraph PLANNER_C["排方案:AI 起草蓝图,同时算你在乎什么<br/>(agent/graph/nodes/planner.py:planner_node)"]
    MODEGATE["范式开关:这轮走哪条路<br/>session 级,请求头/环境变量在进图前已定,不是这里现算的<br/>(state.planner_mode ← schemas/planner_mode.py:resolve_planner_mode)"]
    RULEDIRECT["规则直出:查POI、查餐厅、协商可订时段,一步拼出完整方案<br/>不调用大模型,毫秒级,可断网演示<br/>(_planner_node_rule → planning/planners/rule_planner.py:plan_itinerary)"]
    DUALSTART["权重LLM 与 蓝图LLM 同时发起,互不等待对方结果<br/>各自独立失败,互不牵连<br/>(ThreadPoolExecutor,两个 worker 各管各的异常)"]
    WEIGHTLLM["权重LLM:猜你在乎什么<br/>舒适/时间/成本/连贯 4 个 [0,1] 打分;失败按同行人结构启发式兜底<br/>(planning/weights_llm.py:get_planning_weights)"]
    BLUELLM["蓝图LLM:挑目标、定顺序、定停留多久<br/>只出中间节点(去哪/做什么/停多久),不算时间不算通勤<br/>失败(JSON 非法/字段缺失/旧字段污染)→ 蓝图为空,交给下游兜底<br/>(planning/blueprint/blueprint_llm.py:generate_blueprint)"]
  end

  IN0 --> MODEGATE
  MODEGATE -->|"rule 模式"| RULEDIRECT
  MODEGATE -->|"llm 模式(默认)"| DUALSTART
  DUALSTART --> WEIGHTLLM
  DUALSTART --> BLUELLM

  subgraph ASSEMBLE_C["组装:把蓝图拼成完整时间轴<br/>(agent/graph/nodes/assemble.py:assemble_node)"]
    ASSEMBLECORE["补首尾回家节点;按交通偏好逐段算通勤耗时(4级降级:同地/查真实路网/直线估算/兜底15分钟);<br/>时间游标逐段累加;用餐节点吸附到该店真实可订时段——<br/>吸附不到就诚实保留自然到达时刻,让质检照拦,不硬造一个不存在的时段<br/>(planning/blueprint/assemble_blueprint.py:assemble_from_blueprint)"]
    TRACE["写一份决策留痕:权重的话怎么解释、还比较过哪些备选、质检和降级都经过了什么<br/>(仅此一处注入;规则直出/算法兜底两条路都绕开这里,原生没有留痕——<br/>定稿节点事后会从降级记录里补一份最小留痕,见文件头决策点)<br/>(assemble_node 内联,写 schemas/decision_trace.py:DecisionTrace)"]
  end

  BLUELLM --> ASSEMBLECORE
  ASSEMBLECORE --> TRACE
  WEIGHTLLM -.->|"只喂'你在乎什么'这句解释,不影响蓝图LLM怎么选——<br/>两条LLM并行互不读对方,蓝图LLM的输入里根本没有权重"| TRACE
  RULEDIRECT -->|"内部已经自己调过同一套拼装函数,方案已是成品;<br/>组装节点检测到方案已现成,原样放行(no-op,不重复组装,也不写留痕)"| CRITICCORE

  subgraph CRITIC_C["质检:约 13 条规矩逐条挑毛病<br/>(agent/graph/nodes/critic.py:critic_node)"]
    CRITICCORE["3 段跑法:①结构底线(缺活动节点/时间读不懂/工具没说过这地方——命中任一直接短路)<br/>②硬伤语义(总时长超标/通勤赶不上/满座订不到/没开门/场合不搭/年龄超时/桌型不够/踩忌口/饭点不对)<br/>③软伤建议(比如稍微偏远)——只写进讲解,不拦<br/>itinerary 为空(蓝图没出来)也算硬伤<br/>(planning/critic/validate.py:validate + _rules/checks.py)"]
  end

  TRACE --> CRITICCORE
  CRITICCORE -->|"没查出硬伤;或虽有硬伤但当前是规则模式<br/>(规则模式=不调大模型的承诺,硬伤原样记进留痕但不拦、不回炉)"| FINALIZE_EXIT
  CRITICCORE -->|"有硬伤,且走的是LLM主线路(会回炉)"| REPLANCORE

  subgraph REPLAN_C["没过质检 → 选一种修法<br/>(agent/graph/nodes/replan.py:replan_router_node)"]
    REPLANCORE["数这是第几次重试:第1-2次(默认上限,可调)→回蓝图LLM带着质检意见重写;<br/>第3次→切换算法引擎兜底;重试计数超过总上限(默认4)→放弃,带着现状交卷<br/>每一步决策都记一笔到降级链(供看板/讲解事后读)<br/>(replan.py:replan_router_node)"]
  end

  REPLANCORE -->|"第1-2次:回蓝图LLM,带着质检意见重写<br/>(权重LLM同时重新发起,但不吃这份意见)"| MODEGATE
  REPLANCORE -->|"第3次:切算法引擎兜底"| ILS_POOL
  REPLANCORE -->|"重试超过上限(默认4次):放弃,带着现状(可能仍有硬伤)交卷——<br/>当前接线下这条分支很难被真正触达,见文件头决策点3"| FINALIZE_EXIT

  subgraph ILS_C["备用算法引擎重排:不靠AI也能排出合格方案<br/>(replan.py:ils_replan_node → planning/planners/ils_planner.py:plan_hybrid)"]
    ILS_POOL["重新召回POI/餐厅,先按距离超限/未营业/年龄不合适前置剔除——<br/>别让后面的打分和构造浪费在明显不合适的候选上<br/>(ils_planner.py:_grounding_filter_poi / _grounding_filter_restaurant)"]
    ILS_SCORE["权重LLM 与 语义打分LLM 同时发起(语义打分只对景点,ItiNera范式)<br/>两者都失败兜底:权重按结构启发式、语义分全给中性 0.5<br/>(weights_llm.py + planning/preference_scorer.py:score_pois_with_llm)"]
    ILS_BUILD["贪心插入构造(不是穷举扰动式的局部搜索,那套已被证明是空转并整段删除):<br/>先放用户点名必去的、和条件满足时的软锚饭;<br/>再循环挑边际收益最高的候选插入,插到活动数封顶/时长节奏到点/挑不动为止<br/>(planners/route_builder.py:build_route,可行性靠route_scheduler.py,该填多满靠pace_budget.py)"]
    ILS_CRITIC["拼成方案后,跑一遍同一套质检规矩(同一个检查注册表,另一个调用点,不经过 graph 的质检节点;<br/>仅一处差别:这条路没有搜索快照,防幻觉那条检查在此空转——设计如此,见 critic/context.py)"]
    ILS_REPAIR["有硬伤→按违规类型定向拉黑肇事的那一个(某家店/某个时段/某个景点)→<br/>腾出那一格,只找边际分最高的替补补那一格(不是推倒重来整条重排)<br/>最多修3轮(默认,可调),每轮修完重新质检<br/>(route_builder.py:repair_route,min-conflicts式有界修复)"]
    ILS_FLOOR["修复预算用完仍不干净 → 回落最朴素的规则直出再试一次<br/>(与 RULEDIRECT 同一个函数:planning/planners/rule_planner.py:plan_itinerary)"]
  end

  ILS_POOL --> ILS_SCORE --> ILS_BUILD --> ILS_CRITIC
  ILS_CRITIC -->|"干净,成功兜底"| FINALIZE_EXIT
  ILS_CRITIC -->|"有硬伤,修复预算(默认3轮)还没用完"| ILS_REPAIR
  ILS_REPAIR --> ILS_CRITIC
  ILS_CRITIC -->|"修复预算耗尽仍不干净"| ILS_FLOOR
  ILS_FLOOR -->|"规则地板顶住了,带着这个方案交卷"| FINALIZE_EXIT
  ILS_FLOOR -->|"规则地板也失败,彻底放弃,仍要交卷——真正 hard 卡死(候选彻底耗尽)时附带放宽建议 chips,不再是干巴巴一句道歉<br/>(give_up_chips ← relax_suggestion_chips)"| FINALIZE_EXIT

  subgraph SAFETY["D2安全网:上面这些框如果抛出没预料到的异常(不是正常业务失败,是bug/超时之类)<br/>外面都套了这一层,不让用户看到裸错误<br/>(agent/graph/_resilience.py:drain_on_error,挂载见 build.py 的节点注册处)"]
    RULEFLOOR["垫一个规则地板方案顶上:直接调规则直出;<br/>它自己也失败 → 把原始异常原样抛出,绝不伪造一个假方案<br/>(_resilience.py:_recover_rule_floor)"]
  end

  MODEGATE -.->|"'planner'节点内部任何没预料到的异常"| RULEFLOOR
  ASSEMBLECORE -.->|"'assemble'节点没预料到的异常"| RULEFLOOR
  CRITICCORE -.->|"'critic'节点没预料到的异常"| RULEFLOOR
  REPLANCORE -.->|"'replan_router'节点没预料到的异常"| RULEFLOOR
  ILS_POOL -.->|"'ils_replan'节点没预料到的异常"| RULEFLOOR
  RULEFLOOR -.->|"垫完之后状态变成'规则模式+无硬伤',顺着失败节点原本该走的下一步继续——<br/>多数情况几步之内落到质检,质检因规则模式不拦,直奔定稿(具体落点随失败的是哪一个节点而略有不同)"| CRITICCORE

  subgraph L1OUT["交回 L1:定稿与讲解"]
    FINALIZE_EXIT["起标题+备好待确认订单,方案先推给页面;<br/>出口满足度审计:统一比对最终方案 vs 需求单全部约束,soft 未满足追加 CONSTRAINT_RELAXED 告知(天然覆盖 LLM/ILS/rule 三条路径,不必各自重复比对)<br/>再补暖语气文案、每站的调整按钮、没做到之处的诚实说明<br/>(finalize_plan『含 exit_audit.audit_constraint_relaxation』→ narrate,详见 L1 全景图)"]
  end
