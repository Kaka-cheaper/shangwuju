stateDiagram-v2

    state "TURN_SCOPED字段:本轮专用,共6个 (user_input/route_kind/router_decision/chitchat_reply_text/chitchat_tone/chitchat_chips)" as TURN {
        [*] --> 本轮赋值
        本轮赋值 --> 本轮赋值 : 下一轮make_initial_state整体覆盖为本轮新值,不是「清空」而是「重新赋值」
        %% 证据: state.py:246-258 字段清单+设计理由; state.py:399-415 make_initial_state 显式赋初值
    }

    state "EPISODE_SCOPED字段:随规划事件生灭,共28个 (itinerary/blueprint/violations/critic_feedback_text/user_decision/orders 等)" as EPISODE {
        [*] --> 缺失
        缺失 --> 缺失 : 会话首轮,make_initial_state从不写这批键,读到的是「键缺失」
        %% 证据: state.py:386-398(docstring"完全不碰EPISODE_SCOPED"); test_make_initial_state_covers_exactly_turn_and_session_scoped(state.py:86-91)

        缺失 --> 已重置 : 首次进入规划事件(intent_node/refiner_node调reset_for_new_episode)
        %% 证据: state.py:321-369(reset_for_new_episode实现); intent.py:163-166; refiner.py:60-64

        已重置 --> 已重置 : 首轮reset铺的零值与「键缺失」读数等价,无可观察差异(no-op)
        %% 证据: state.py:331-333(reset docstring"首轮no-op"); test_intent_node_reset_is_noop_on_first_turn(test_state_lifecycle.py:99-130)

        已重置 --> 本轮业务值 : 节点自身输出在同一次return里覆盖reset diff(reset先铺底,业务输出后覆盖)
        %% 证据: intent.py:166 return{**reset_for_new_episode(),**out}; refiner.py:61-64 同款合并顺序

        本轮业务值 --> 本轮业务值 : 同一规划事件内的重排/降级循环(planner/assemble/critic/replan_router/ils_replan反复改写,不整档清零)
        %% 证据: build.py:270-312(critic/replan_router/ils_replan拓扑); replan.py:157-166(ils成功分支只覆写violations=[]/critic_feedback_text=None等具体字段)

        本轮业务值 --> 跨轮存活 : 之后若干轮是chitchat等不触发新规划事件的动作,make_initial_state不碰这批字段,原样保留
        %% 证据: state.py:94-98(EPISODE_SCOPED类注释"persistence by omission")

        跨轮存活 --> 跨轮存活 : 继续停留在同一规划事件(如换菜/查询/确认,详见下方user_decision子状态机)
        %% 证据: state.py:94-98 同上

        跨轮存活 --> 已重置 : 会话中期再次触发新规划事件(新需求进intent_node,或反馈进refiner_node),陈旧残留必须被清零
        %% 证据: test_intent_path_resets_episode_state_mid_session(test_state_lifecycle.py:152-241,ADR-0012背景5"定时炸弹"场景重现)
    }

    state "user_decision确认态:EPISODE_SCOPED里单独画的一个字段,因为写手只有HTTP旁路 (state.user_decision)" as DECISION {
        [*] --> None未确认
        None未确认 --> None未确认 : 同EPISODE_SCOPED的缺失/已重置态,都读作None
        %% 证据: state.py:360(reset diff里 user_decision:None)

        None未确认 --> confirm已确认 : 确认端点执行成功后,同步aupdate_state回写(不是图内节点写的,是HTTP旁路)
        %% 证据: api/_streams/graph_confirm.py:290-355(_writeback_graph_state,as_node="narrate"); build.py:33-40(ADR-0012决策2"结构诚实,confirm不进图")

        confirm已确认 --> confirm已确认 : 会话继续但不触发新规划事件(如chitchat/换菜),按persistence by omission保留；换菜端点读它做守门
        %% 证据: api/_streams/graph_adjust.py:161-168(user_decision=="confirm"时拒绝静默换菜)

        confirm已确认 --> None未确认 : 下一次规划事件的reset_for_new_episode()清零——这是ADR-0012原文承认的「已知丢失窗口」
        %% 证据: state.py:188-195,276-279(注释"已知丢失标注:user_decision/orders")
    }

    note right of DECISION
        我不确定:Literal声明confirm/refine/cancel三态,但全仓检索只找到
        「confirm」这一个值被写进过图checkpoint(graph_confirm.py:351)。
        「refine」/「cancel」只出现在memory_writer的单测/校验脚本里,
        没有任何运行时路径把它们写回图状态——本图因此只画得出
        「confirm」这一条被实证的迁移,另外两态是否曾被设计为可达,
        需要作者确认。
    end note

    state "SESSION_SCOPED字段:跨轮持久,共7个 (messages/demand_ledger/plan_version_log/user_id/session_id/scenario_id/planner_mode)" as SESSION {
        [*] --> 会话诞生
        会话诞生 --> 持续累积 : make_initial_state每轮透传user_id/session_id等同一份值(是「确认」不是「重置」)
        %% 证据: state.py:399-415(make_initial_state); state.py:260-268(SESSION_SCOPED字段清单)

        持续累积 --> 持续累积 : messages靠add_messages/plan_version_log靠operator.add/demand_ledger靠自定义归并器,每轮「空更新=保留旧值」
        %% 证据: state.py:69-81(_merge_demand_ledger); state.py:221-236(plan_version_log归并器选型说明)

        持续累积 --> 持续累积 : 跨越任意多个turn/规划事件,从不被TURN或EPISODE两种重置动到
        %% 证据: state.py:260-279(SESSION_SCOPED类注释)
    }

    note right of SESSION
        无终态:本仓未见「会话结束清理」路径。checkpoint/messages通道
        被显式接受为demo规模下无界增长,修剪留给未来的上下文打包器
        保险丝层,不在存储层做。
    end note
    %% 证据: state.py:122-128(护栏4原文"存储无界,二选一显式拍板")

    state "诉求台账条目状态机:demand_ledger列表里每一条LedgerEntry.status (颗粒度比字段更细——字段本身是SESSION_SCOPED,条目内部另有三态)" as LEDGER {
        [*] --> ACTIVE生效
        ACTIVE生效 --> ACTIVE生效 : 换菜端点点击定向调整按钮时追加新条目,新条目默认ACTIVE
        %% 证据: schemas/demand_ledger.py:120(默认值ACTIVE); api/_streams/graph_adjust.py:207-225(record_demand调用点)

        ACTIVE生效 --> SUPERSEDED被顶替 : 同一member_id+node_ref+dimension三元组写入新条目时,旧的ACTIVE条目被标记
        %% 证据: schemas/demand_ledger.py:134-166(record_demand顶替规则,原地保留不删除)

        ACTIVE生效 --> SATISFIED已满足 : 换菜命中degrade_tier为1或2(谓词确实被满足,非近似)时消费方显式调用mark_satisfied
        %% 证据: schemas/demand_ledger.py:169-206(mark_satisfied); api/_streams/graph_adjust.py:226-230(仅tier 1/2才调用)

        SUPERSEDED被顶替 --> SUPERSEDED被顶替 : 原地保留,不再被后续操作动到(终态)
        %% 证据: schemas/demand_ledger.py:149-150("已是SUPERSEDED/SATISFIED的既有条目不会被本函数动到")

        SATISFIED已满足 --> SATISFIED已满足 : 同上,终态
        %% 证据: schemas/demand_ledger.py:149-150 同上
    }

    note right of LEDGER
        条目随demand_ledger字段的SESSION_SCOPED生命周期存活,不随
        规划事件清零(ADR-0013决策3「诉求不随重排自动死」)。这里画的
        是列表内每条记录自己的三态微观状态机,与外层TURN/EPISODE/
        SESSION是两个不同的观察颗粒度,不要混为一谈。
    end note
