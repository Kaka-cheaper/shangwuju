%% ============================================================
%% L1-a · 回合流水线全景 —— 这张图回答:「用户的一次动作,系统从头到尾做了什么」
%% 受众: 有基础知识的非开发者也要能读懂(人话为主) + 开发者可定位(括号内代码名)
%% 文字纪律: 每框第一行人话职责,括号内是代码里的名字;不出现未解释的内部代号
%% 基于 commit: bf8ff23 (2026-07-03) · 材料: 主线全量勘探报告
%% ============================================================
flowchart TB

  subgraph FE["用户在页面上做的事(前端 frontend/)"]
    U1["说一句话,或点一张场景卡<br/>(sendMessage / sendScenario)"]
    U2["对方案提意见,比如「太远了」<br/>(refine)"]
    U3["点「确认并预约」按钮<br/>(confirm)"]
    U4["点某一站下面的调整按钮<br/>换一家 / 更便宜的 / 点踩"]
    U5["多人房间里发言、投票、操作<br/>(协作模式)"]
  end

  U1 --> TURN["对话入口<br/>(POST /chat/turn)"]
  U2 --> TURN
  U3 --> CONF["确认下单入口<br/>(POST /chat/confirm)"]
  U4 -->|"单人模式"| ADJ["换菜入口<br/>(POST /chat/adjust)"]
  U4 -->|"房间模式"| WS
  U5 --> WS["房间实时通道<br/>(WebSocket /ws/:room_id)"]

  subgraph GRAPH["大脑主流程(LangGraph 编排 · agent/graph/build.py)"]
    ROUTER["分诊台:先听懂这句话想干嘛<br/>安全检查→熟语直通→AI 判断→保守兜底<br/>(router · 点击展开子图)"]
    CHIT["陪聊与引导:不动方案<br/>回一句贴心话+可点的建议按钮<br/>(chitchat,到此结束)"]
    INTENT["把一句话读成结构化需求单<br/>时间/同伴/口味/氛围…读不准会重试<br/>(intent · parse_intent)"]
    REFINER["把新意见合并进原需求单<br/>会参考你之前说过和点过的诉求<br/>(refiner)"]
    W1["查景点<br/>(search_pois)"]
    W2["查餐厅<br/>(search_restaurants)"]
    W3["查你的偏好档案<br/>(get_user_profile)"]
    COLLECT["三路同时查,查完集合<br/>(execute_collect)"]
    PLANNER["排方案:AI 起草行程蓝图<br/>同时算你在乎什么(权重)<br/>断网时走纯规则版(planner)"]
    ASSEMBLE["把蓝图拼成完整时间轴<br/>含用餐时刻对齐餐厅真实可订时段<br/>(assemble)"]
    CRITIC["质检:13 条硬规矩逐条挑毛病<br/>时长/距离/赶不赶得上/满不满座…<br/>(critic)"]
    REPLAN["没过质检→选一种修法<br/>(replan_router)"]
    ILS["备用算法引擎重排<br/>不靠 AI 也能排出合格方案<br/>(ils_replan)"]
    FINAL["定稿:起标题+备好待确认订单<br/>方案立刻先推给页面,不等文案<br/>(finalize_plan)"]
    NARR["写讲解:开场白+每站的调整按钮<br/>+没做到之处的诚实说明<br/>(narrate)"]
  end

  TURN --> ROUTER
  ROUTER -->|"闲聊/问题/不清楚/攻击"| CHIT
  ROUTER -->|"第一次提需求"| INTENT
  ROUTER -->|"对方案提意见"| REFINER
  INTENT --> W1 & W2 & W3
  REFINER --> W1 & W2 & W3
  W1 --> COLLECT
  W2 --> COLLECT
  W3 --> COLLECT
  COLLECT --> PLANNER --> ASSEMBLE --> CRITIC
  CRITIC -->|"合格"| FINAL
  CRITIC -->|"有硬伤"| REPLAN
  REPLAN -->|"把毛病告诉 AI 重写(最多 2 次)"| PLANNER
  REPLAN -->|"AI 修不动→换算法"| ILS
  REPLAN -->|"实在修不好→带说明交卷"| FINAL
  ILS --> FINAL
  FINAL --> NARR

  subgraph BYPASS["三条近道(不进大脑主流程,直接执行,做完把结果写回对话记忆)"]
    GATE["已下单守门<br/>确认过的方案不许静默换菜<br/>想改就说「重新规划」"]
    SWAP["换菜引擎:只动这一站<br/>其他站不动;找不到同类逐级放宽并告知<br/>(resolve_node_swap)"]
    EXEC["执行订单:订座/买票/加购/生成分享文案<br/>顺手记住你这次的偏好<br/>(execute_finalize)"]
    ROOM["房间管家:谁说了什么都记名<br/>调整排队逐个处理;闲置 50 分钟自动销毁<br/>(RoomManager)"]
  end

  CONF --> EXEC
  EXEC -.->|"订单结果写回对话记忆"| GRAPH
  ADJ --> GATE --> SWAP
  SWAP -.->|"新方案+诉求账本写回对话记忆"| GRAPH
  WS --> ROOM
  ROOM -->|"要重新规划时,走一遍大脑主流程"| GRAPH
  ROOM -->|"房间里的换菜/点踩"| SWAP
  ROOM -->|"房主确认下单"| EXEC

  CHIT --> SSE
  NARR --> SSE["实时事件流:边算边推过程<br/>让页面能看到系统在干什么<br/>(SSE · 14 种事件)"]
  EXEC --> SSE
  SWAP --> SSE
  SSE --> STORE["页面更新<br/>方案卡/时间轴/聊天气泡/诉求台账<br/>(前端 event-handlers)"]

  subgraph INFRA["底座:上面所有环节都在用的公共设施"]
    PROJ["会话速查缓存<br/>确认下单时快速取当前方案<br/>(SESSION_STORE)"]
    CKPT["对话记忆存档<br/>跨轮次记住整场对话<br/>(checkpointer)"]
    PACK["上下文打包器<br/>把对话史整理成 AI 能读的摘要<br/>(agent/context)"]
    LLMC["AI 通道<br/>真模型/备用双发/本地假模型三档<br/>(llm_client)"]
    SAFE["安全网<br/>出错逐级降级不白屏+防提示词注入<br/>(drain_on_error + prompt_guard)"]
    DATA["演示数据与口径<br/>景点/餐厅/路程数据,距离统一读法<br/>(data/ + mock_data/)"]
  end

  %% ---- 点击跳转子图(anchors.json 同源生成的导航面) ----
  click ROUTER "#L2-routing-cascade" "展开:分诊台内部"
  click INTENT "#L2-constraint-dataflow" "展开:约束数据流"
  click REFINER "#L2-constraint-dataflow" "展开:约束数据流"
  click PLANNER "#L2-planning-pipeline" "展开:规划求解管线"
  click ASSEMBLE "#L2-planning-pipeline" "展开:规划求解管线"
  click CRITIC "#L2-planning-pipeline" "展开:规划求解管线"
  click REPLAN "#L2-planning-pipeline" "展开:规划求解管线"
  click ILS "#L2-planning-pipeline" "展开:规划求解管线"
  click FINAL "#L2-planning-pipeline" "展开:规划求解管线"
  click GATE "#L2-node-swap" "展开:换菜引擎"
  click SWAP "#L2-node-swap" "展开:换菜引擎"
  click EXEC "#L2-confirm-execution" "展开:确认执行流"
  click ROOM "#L2-collab-room" "展开:房间协作"
  click PROJ "#L2-session-substrate" "展开:会话底座"
  click CKPT "#L2-session-substrate" "展开:会话底座"
  click PACK "#L2-session-substrate" "展开:会话底座"
