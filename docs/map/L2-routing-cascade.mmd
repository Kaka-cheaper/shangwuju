%% ============================================================
%% L2 · 分诊台级联展开 —— 这张图回答:「一句话进来,分诊台怎么决定它是什么义务」
%% 这是 L1 全景图里「分诊台」黑盒(ROUTER · router_node,当时标注"正在重写,详见子图")的展开
%% 受众: 有基础知识的非开发者也要能读懂(人话为主) + 开发者可定位(括号内代码名)
%% 文字纪律: 每框第一行人话职责,括号内是代码里的名字;连线条件也是人话
%% 基于 commit: 57afcef(E-2-c 统一路由脑子改造落地于 commit 5321d8d,本图画的是落地后的终形)
%% ------------------------------------------------------------
%% 锚点表(路径均相对 backend/;函数/类名见对应节点括号内)
%%   agent/routing/route_turn.py            route_turn() —— 级联主控,唯一真相源
%%   agent/graph/nodes/router.py             router_node() / route_after_router() —— graph 侧适配器与出口分流
%%   agent/core/injection_detector.py        detect_injection() —— 壳1
%%   agent/routing/canonical_shortcut.py     canonical_shortcut_decision() —— 壳2
%%   agent/intent/prompts/router_prompt.py   PRIMARY_CTAS / FLOOR_CLARIFY_CTAS —— 壳2 字面来源(含 DEMO_SCENARIOS)
%%   agent/core/feedback_detector.py         looks_like_feedback_strong() —— Layer 1
%%   agent/core/persona_qa.py                build_persona_decision() —— Layer 1.7
%%   agent/core/itinerary_qa.py              build_question_decision() —— Layer 1.8·方案问答
%%   agent/core/dialogue_acts.py             build_booking_decision() / build_confirm_decision() —— Layer 1.8·预约/确认
%%   agent/core/soft_constraint_sniffer.py   build_soft_constraint_decision() —— Layer 1.8·软约束嗅探
%%   agent/context/sources.py                GraphStateSource / RoomSource —— 上下文来源(底座无关)
%%   agent/context/packer.py                 pack_routing_context() —— 上下文打包(纯函数)
%%   agent/context/types.py                  RoutingContext.render_text() —— 打包产出的序列化
%%   agent/routing/brain.py                  classify_turn() / _apply_confidence_floor() / _apply_label_chip_policy() —— 统一脑子
%%   agent/routing/brain_prompt.py           BRAIN_SYSTEM_PROMPT / BRAIN_FEW_SHOTS —— 脑子的判据与少样本
%%   agent/intent/router.py                  fallback_decision() / make_planning_decision() —— 壳3 / 壳2 决策构造器
%%   agent/routing/kinds.py                  RouteKind —— 6 值闭集定义
%%   agent/routing/outcome.py                RouteOutcome —— 级联的类型化返回值(kind/decision/injection_blocked)
%%   schemas/router.py                       RouterDecision / InputKind / CtaChip —— 决策载荷契约
%% ============================================================
flowchart TB

  ADAPTER["分诊台的入口/出口壳:把 state 摊平交给级联主干判断<br/>判完摊回 state,顺带把这轮的话+气泡回话记进会话日志(供打包器下次读)<br/>(router_node · graph/nodes/router.py)"]
  IN["这一轮用户说的话<br/>+ 当前会话是否已有方案 + 是谁<br/>(utterance · itinerary · user_id)"]
  ADAPTER --> IN

  subgraph CASCADE["级联主干:命中即停,逐层判断要不要动用更贵的判断力(route_turn 顶层控制流)"]
    S1["壳1·安全检查:这句话想劫持系统吗<br/>「动作词+对象词」正则,零成本,检测器自身出错也放行(fail-open)<br/>(detect_injection)"]
    S2["壳2·熟语直通:这句话是系统自己发出、用户原样点回来的文案吗<br/>精确字面匹配,FP≈0,不做语义/关键词猜测<br/>(canonical_shortcut_decision)"]
    L1STRONG["Layer 1·强反馈直觉:这句话像不像在嫌弃现有方案<br/>关键词+数字单位正则;仅在已有方案时判,无方案必不命中<br/>(looks_like_feedback_strong)"]
    L17["Layer 1.7·画像问答:在问「我是谁/我的偏好」吗<br/>规则识别,不调 AI;不论有没有方案都判<br/>(build_persona_decision)"]
  end

  LITERALS["三处「系统自己吐出的文案」字面库<br/>引导按钮 ∪ 演示场景卡 ∪ 地板三选项<br/>(PRIMARY_CTAS ∪ DEMO_SCENARIOS ∪ FLOOR_CLARIFY_CTAS)"]
  LITERALS -.->|"比对字面用"| S2

  IN --> S1
  S1 -->|"命中攻击特征(角色劫持/指令覆盖/prompt泄露/分隔符伪造/越狱)"| OUT_DEFENSE
  S1 -->|"未命中"| S2

  S2 -->|"命中引导按钮/演示场景字面(不看有没有方案)"| OUT_PLANNING
  S2 -->|"命中「重新规划一个」(需已有方案)"| OUT_PLANNING
  S2 -->|"命中「调整一下方案」(需已有方案)"| OUT_FEEDBACK
  S2 -->|"命中「就这样挺好」(需已有方案)→纯认可,不带按钮"| OUT_CONFIRM
  S2 -->|"都未命中"| L1STRONG

  L1STRONG -->|"命中(太远/太赶/太贵/N公里以内…)"| OUT_FEEDBACK
  L1STRONG -->|"未命中"| L17

  L17 -->|"命中"| OUT_CHITCHAT
  L17 -->|"未命中 且 当前无方案→Layer 1.8 整层跳过"| BRAIN
  L17 -->|"未命中 且 当前有方案→依次判 Layer 1.8"| L18QA

  subgraph SHELL18["Layer 1.8·会话内规则判定(仅当前会话已有方案时才整层跑;各条不调 AI 主判定)"]
    L18QA["方案问答:在问方案里的事吗(贵不贵/远不远/几点开)<br/>疑问句式规则识别+按数据模板作答;查不到字段时可能追加一次窄范围 AI 措辞(那是弃答话术,不是路由判断)<br/>(build_question_decision · itinerary_qa)"]
    L18BOOK["预约指令:在主动喊「帮我订/预约吧」吗<br/>关键词规则,不调 AI<br/>(build_booking_decision · dialogue_acts)"]
    L18CONFIRM["纯确认:在说「好的/就这样/没意见」吗<br/>关键词规则,不调 AI<br/>(build_confirm_decision · dialogue_acts)"]
    L18SOFT["软约束嗅探:话里藏着没明说要改的硬要求吗(老人腿脚不好/不吃辣)<br/>词典规则优先;规则未命中且句子有实义时可能追加一次窄范围 AI 判词典 tag(同样不是路由判断);若已经明说「换成/改成」则不算命中,直接放行<br/>(build_soft_constraint_decision · soft_constraint_sniffer)"]
  end

  L18QA -->|"命中"| OUT_CHITCHAT
  L18QA -->|"未命中"| L18BOOK
  L18BOOK -->|"命中→带唯一「确认预约」按钮"| OUT_CONFIRM
  L18BOOK -->|"未命中"| L18CONFIRM
  L18CONFIRM -->|"命中→纯认可,不带按钮"| OUT_CONFIRM
  L18CONFIRM -->|"未命中"| L18SOFT
  L18SOFT -->|"命中→主动问一句+转正按钮"| OUT_CHITCHAT
  L18SOFT -->|"未命中→Layer 1.8 全部落空"| BRAIN

  subgraph BRAINGRP["统一路由脑子:级联里唯一会调用大模型做主判定的一步(ADR-0011 E-2-c)"]
    CTXSRC["会话材料来源:单人主聊天状态 / 协作房间<br/>各自把自己的历史·台账·画像形状翻译成统一协议<br/>(GraphStateSource / RoomSource)"]
    CTXPACK["上下文打包器:把对话史/方案版本志/方案摘要/画像/台账整理成脑子能读的一段话<br/>纯函数,不调 AI;只在真要调脑子时才打包,前面命中就省这份成本<br/>(pack_routing_context → RoutingContext.render_text())"]
    BRAIN["统一路由脑子:一次 AI 判断这轮欠用户哪种回应<br/>吃会话上下文+本轮输入+是否已有方案,判 6 类之一 + 置信度 + 槽位(node_ref/feedback_hint)<br/>(classify_turn · brain.py)"]
    BRAINPOST["置信度地板 + 按钮纪律:置信度不到 0.6(且原判不是 clarify)就整体覆盖成「澄清」保守文案,不论原本判的是哪一类;<br/>判成「确认」就无视 AI 提的按钮,强制换成唯一「确认预约」<br/>(_apply_confidence_floor · _apply_label_chip_policy)"]
    CTXSRC --> CTXPACK
    CTXPACK -.->|"打包结果喂给脑子当输入材料"| BRAIN
    BRAIN -->|"判成功"| BRAINPOST
  end

  BRAIN -->|"AI 调用异常/超时/坏JSON/schema 校验不过"| SHELL3

  BRAINPOST -->|"planning"| OUT_PLANNING
  BRAINPOST -->|"feedback"| OUT_FEEDBACK
  BRAINPOST -->|"chitchat"| OUT_CHITCHAT
  BRAINPOST -->|"confirm→强制换成唯一「确认预约」按钮"| OUT_CONFIRM
  BRAINPOST -->|"clarify(含被置信度地板拍成的)"| OUT_CLARIFY
  BRAINPOST -->|"defense(非注入,如让写代码这类越界请求)"| OUT_DEFENSE

  SHELL3["壳3·保守地板:AI 判不出来时退到最保守的应对,绝不默认规划/重规划<br/>无方案→陪聊引导(带 3 个场景按钮);有方案→澄清引导(带调整/重排/挺好 三选项按钮)<br/>(fallback_decision)"]
  SHELL3 -->|"无方案"| OUT_CHITCHAT
  SHELL3 -->|"有方案"| OUT_CLARIFY

  subgraph EXITS["六个出口标签(RouteKind 闭集 · agent/routing/kinds.py)"]
    OUT_PLANNING["出口·满足-首轮 planning<br/>没有对用户展示的气泡(decision 若存在也只是内部占位文案)"]
    OUT_FEEDBACK["出口·满足-反馈 feedback<br/>没有对用户展示的气泡,同 planning"]
    OUT_CHITCHAT["出口·陪聊 chitchat<br/>变气泡,不动方案,聊完就结束"]
    OUT_CONFIRM["出口·确认 confirm<br/>变气泡;主动预约/脑子判定→带唯一「确认预约」按钮,纯认可→不带按钮"]
    OUT_CLARIFY["出口·澄清 clarify<br/>变气泡,反问+选项,不猜一个方向就动手"]
    OUT_DEFENSE["出口·防御 defense<br/>变气泡,得体拒绝+引导回主路径;壳1命中会带 injection_blocked=True(会话日志打码),脑子判定则不带"]
  end

  subgraph DOWNSTREAM["出口流向哪(详见 L1 全景图)"]
    DOWN_INTENT["需求单抽取<br/>(intent 节点)"]
    DOWN_REFINER["合并意见<br/>(refiner 节点)"]
    DOWN_CHITCHAT["陪聊与引导(气泡)<br/>(chitchat 节点)"]
  end

  OUT_PLANNING -->|"route_after_router"| DOWN_INTENT
  OUT_FEEDBACK -->|"route_after_router"| DOWN_REFINER
  OUT_CHITCHAT -->|"route_after_router 兜底"| DOWN_CHITCHAT
  OUT_CONFIRM -->|"route_after_router 兜底"| DOWN_CHITCHAT
  OUT_CLARIFY -->|"route_after_router 兜底"| DOWN_CHITCHAT
  OUT_DEFENSE -->|"route_after_router 兜底"| DOWN_CHITCHAT
