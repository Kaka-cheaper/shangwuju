%% 前置阅读: docs/map/L1-modules.mmd / L1-turn-pipeline.mmd / index.html 的 L0 术语表
%%           (「需求单」=IntentExtraction,「诉求台账」=demand_ledger,「质检」=critic,
%%            「兜底」=fallback/drain —— 本图沿用这套词,不新造术语)
%% ----
%% 【这是什么】ADR-0014(需求分析环节治理)的作业底图。上一版画的是 2026-07-03
%%   全链路只读审查*当时*发现的九处断链;此后 G-0~G-4b 六个批次(3b217f6/
%%   206de2e/53ba99b/711a034/60f6130 等)+ 横向深审四发现的处置批(b15fee5/
%%   f46423d/a88c96b)+ 降级演练追加批(3113332)已陆续把七处收口——本图这版
%%   按 docs/adr/0014-requirement-analysis-provenance-and-hard-constraints.md
%%   「落地状态」节 + 读码逐条核实重画:管道基本不再
%%   漏水,只剩 E-3 挂钩的两项还在断链区(parse_confidence 的置信度→追问分支、
%%   台账"全局诉求"形态的写手),其余七处已画成实线/移出断链区。
%% ----
%% 【图例】
%%   实线 -->   = 当前代码里真实在跑的消费/写入边(有 grep/读码实锤)
%%   虚线 -.->  = 断链 / 非直接(需用户点击中转) / 派生但未真正接线
%%   ❌ 前缀    = 仍然成立的已知缺口(现仅剩 2 处,均归 E-3)
%% ----
%% 【锚点表:节点 id → 代码位置】
%%   W1_PARSE       agent/intent/parser.py::parse_intent + _apply_provenance_correction ;
%%                  agent/graph/nodes/intent.py::intent_node
%%   W2_REFINE      agent/intent/refiner.py::refine_intent + _propagate_field_provenance ;
%%                  agent/graph/nodes/refiner.py::refiner_node
%%   W3_LEDGER_WRITE  schemas/demand_ledger.py::record_demand ; api/_streams/graph_adjust.py ; collab/room.py
%%   W4_SNIFFER     agent/core/soft_constraint_sniffer.py::build_soft_constraint_decision
%%   L_INTENT       schemas/intent.py::IntentExtraction (存于 AgentState["intent"];
%%                  field_provenance 字段 · G-1 · 194-214;budget_per_person 字段 · G-3 · 172-183)
%%   L_LEDGER       schemas/demand_ledger.py::LedgerEntry (存于 AgentState["demand_ledger"] / Room.demand_ledger)
%%   C1_SEARCH      tools/_helpers.py::relax_tag_search(hard 恒不放宽,soft 按 field_provenance
%%                  排序渐进丢,hard 打空候选记结构化日志) ; tools/search_pois.py ; tools/search_restaurants.py
%%   C2_BLUEPRINT   agent/planning/blueprint/blueprint_llm.py
%%   C3_WEIGHTS     agent/planning/weights_llm.py::get_planning_weights
%%   C4_CRITIC      agent/planning/critic/_rules/checks.py::check_dietary(hard-only ALL-match,已改判) /
%%                  check_physical(G-2 新增,与 check_dietary 对称) / check_capacity / check_budget(G-3 新增,SOFT)
%%   C5_PACEBUDGET  agent/planning/planners/pace_budget.py::pace, interval_fill_targets
%%   C6_NARRATE     agent/graph/nodes/narrate.py ; agent/intent/narrator.py(_provenance_hints/
%%                  _provenance_honest_clause · G-1/G-3 两个消费方:出处默认值/inferred 标签 + 预算
%%                  听到没法量化)
%%   C7_PACKER      agent/context/packer.py::pack_routing_context, render_demand_recap ; agent/context/types.py
%%   C8_SWAP        agent/planning/planners/node_swap.py::resolve_node_swap (ledger_slice 形参 +
%%                  _filter_hard_violations/_audit_swapped_node · ADR-0014 横向深审 P0,详见 L2-node-swap.mmd)
%%   C9_ADVISORY    schemas/advisory.py::Advisory ; ils_planner.py::_build_success_advisories ; node_swap.py 降级序列
%%   EXIT_AUDIT     agent/planning/critic/exit_audit.py::audit_constraint_relaxation(G-2,挂 finalize_plan_node,
%%                  详见 L2-planning-pipeline.mmd)
%%   SSE_DEBUG      agent/graph/_emit_handlers.py::emit_fanout_worker (tool_call_end.relaxed_tags)
%%   ROUTER_BRAIN   agent/routing/brain.py::classify_turn
%%   G_*            仍然成立的断链(仅 2 项,归 E-3;见各节点文字与背景 docstring 引用行号)
%% ============================================================
flowchart TB

  subgraph WRITERS["四个写手 —— 诉求从人嘴里/点击里怎么进系统"]
    W1_PARSE["首轮抽取:第一句话读成结构化需求单;自报字段出处四值枚举+规则交叉校正<br/>(数字标量命中'值=先验且原话未提'→机械改判 prior;social_context 豁免此规则——<br/>它本就几乎恒为 inferred,字面等值不是'抄先验'信号,今日 P1 修)<br/>(intent/parser.py::parse_intent + _apply_provenance_correction,经 graph/nodes/intent.py)"]
    W2_REFINE["反馈合并:把新意见并进原需求单(LLM 或关键词兜底);出处纯规则传播(变更字段→user_stated,<br/>未动继承,撤回清理,重申先验→升级 user_stated——不要 LLM 自报)<br/>(intent/refiner.py::refine_intent + _propagate_field_provenance,经 graph/nodes/refiner.py)"]
    W3_LEDGER_WRITE["点击记账:仅「定向调整」按钮落账;点踩/具名备选不记(选定不是诉求)<br/>(demand_ledger.py::record_demand,经 api/_streams/graph_adjust.py + collab/room.py)"]
    W4_SNIFFER["陪聊嗅探:闲聊里听出隐含硬约束,只问不改,不自己写任何东西<br/>(core/soft_constraint_sniffer.py)"]
  end

  subgraph LEDGERS["两本账"]
    L_INTENT["需求单:当前有效的合并视图(单一对象,反馈整体覆盖)<br/>(schemas/intent.py::IntentExtraction)"]
    L_LEDGER["诉求台账:记名的诉求事件史(生效/被顶替/已满足,原地留痕不删除)<br/>(schemas/demand_ledger.py::LedgerEntry)"]
  end

  W1_PARSE -->|"含 field_provenance(G-1)+budget_per_person(G-3,仅明说数字才填)"| L_INTENT
  L_INTENT --> W2_REFINE
  W2_REFINE -->|"覆盖式合并(model_copy update),raw_input 累积拼接,field_provenance 同步纯规则重算"| L_INTENT
  L_LEDGER -->|"读现有账目做顶替判定(member+node_ref+dimension 三元组)"| W3_LEDGER_WRITE
  W3_LEDGER_WRITE -->|"record_demand:整体替换成含顶替改写的新全量列表"| L_LEDGER
  W4_SNIFFER -.->|"只产出建议 chip;用户点击后文案重入路由→强反馈判定→W2 才真正写入(非直接写)"| W2_REFINE

  subgraph CONSUMERS["消费面 —— 两本账喂给谁、影响了方案的什么"]
    C1_SEARCH["搜索过滤与降级链:hard(忌口/无障碍类)一票否决永不放宽;soft 按出处 2×2 矩阵渐进丢<br/>(prior/default 先丢不打扰,user_stated 丢了必告知);hard 打空候选记结构化日志<br/>(tools/_helpers.py::relax_tag_search,经 search_pois.py + search_restaurants.py)"]
    C2_BLUEPRINT["蓝图 prompt:整份需求单 JSON 灌给 AI 起草行程蓝图<br/>(planning/blueprint/blueprint_llm.py)"]
    C3_WEIGHTS["打分权重:同行人结构+场景算 4 维 utility 权重<br/>(planning/weights_llm.py::get_planning_weights)"]
    C4_CRITIC["质检:dietary(hard-only ALL-match)/physical(G-2 新增,与 dietary 对称)逐节点核验/<br/>桌型够不够/预算超没超(G-3 新增,SOFT,仅明说数字才比)<br/>(critic/_rules/checks.py::check_dietary, check_physical, check_capacity, check_budget)"]
    C5_PACEBUDGET["降级链(节奏留白):从同行人+场景独立重推节奏档,不读需求单任何节奏字段<br/>(planning/planners/pace_budget.py::pace, interval_fill_targets)"]
    C6_NARRATE["叙事诚实告知:开场白+调整按钮+没做到之处如实说明+出处诚实告知(距离缺省/首个 inferred 标签)+<br/>预算听到没法量化<br/>(graph/nodes/narrate.py + intent/narrator.py::_provenance_hints/_provenance_honest_clause)"]
    C7_PACKER["上下文打包器:台账生效切片打包成三方共用只读快照<br/>(context/packer.py::pack_routing_context)"]
    C8_SWAP["换菜引擎:生效诉求作为候选池优先级偏置;候选池 hard 恒定过滤+换后单点 soft 审计<br/>(ADR-0014 横向深审 P0,详见 L2-node-swap.mmd)<br/>(planning/planners/node_swap.py::resolve_node_swap 的 ledger_slice)"]
    C9_ADVISORY["规划器诚实告知通道:方案办不到时的结构化理由<br/>(schemas/advisory.py::Advisory)"]
    EXIT_AUDIT["出口满足度审计:定稿时统一比对最终方案 vs 需求单全部约束——dietary/physical 逐节点判、<br/>experience_tags 整段并集判,soft 未满足→CONSTRAINT_RELAXED(详见 L2-planning-pipeline.mmd)<br/>(critic/exit_audit.py::audit_constraint_relaxation,挂 finalize_plan_node)"]
  end

  SSE_DEBUG["SSE 工具调用调试字段(仅调试展示,非叙事素材)<br/>(graph/_emit_handlers.py::emit_fanout_worker 的 tool_call_end.relaxed_tags)"]
  ROUTER_BRAIN["路由脑子 prompt:判这句话该走哪条分支<br/>(routing/brain.py::classify_turn)"]
  NOTE_RELAX["备注:relaxed_tags 本身仍只进调试字段,不直接喂 narration——但这不再是断链:<br/>G-2 出口审计(EXIT_AUDIT)独立比对最终方案 vs 需求单,已经接管了'软约束被放宽要诚实告知用户'这件事;<br/>relaxed_tags 降级为纯调试信息是 ADR-0014 决策 2 的明确拍板,不是遗留 bug"]

  L_INTENT -->|"physical/dietary/experience_tags 三词典,按 hard/soft 分层(is_hard_tag)+ field_provenance 驱动降级序(extract_tag_provenance)"| C1_SEARCH
  L_INTENT -->|"model_dump_json() 整份灌入(仅 raw_input/companions/preferred_poi_types 等自由文本无出处标注)"| C2_BLUEPRINT
  L_INTENT -->|"social_context+companions+tags+raw_input"| C3_WEIGHTS
  L_INTENT -->|"dietary_constraints/physical_constraints/capacity_requirement/budget_per_person"| C4_CRITIC
  L_INTENT -->|"companions+social_context(pace_profile 字段已砍除,G-0——本就无消费方,收缩契约迁到 duration_hours)"| C5_PACEBUDGET
  L_INTENT -->|"评分/节奏上下文(resolve_node_swap 内部默认调用同一函数)+ dietary/physical hard 子集(候选池恒定过滤)+ field_provenance(换后单点审计出处口径)"| C8_SWAP
  L_INTENT -->|"field_provenance(出处默认值/首个 inferred 标签)+ ambiguous_fields(预算听到没法量化,G-3 首个真实消费方)"| C6_NARRATE
  L_INTENT -->|"dietary_constraints/physical_constraints/experience_tags + field_provenance(口径措辞)"| EXIT_AUDIT

  L_LEDGER -->|"demand_ledger_raw()→ledger_active_global/named"| C7_PACKER
  L_LEDGER -->|"active_adjustments(ledger,node_ref=...)→ledger_slice 优先级偏置"| C8_SWAP

  C3_WEIGHTS -.->|"resolve_node_swap 内部默认复用同一打分函数(get_planning_weights)"| C8_SWAP
  C5_PACEBUDGET -->|"budget_min=interval_fill_targets(...).hi_min(节点修复重用同一节奏预算)"| C8_SWAP

  C8_SWAP --> C9_ADVISORY
  C4_CRITIC -->|"SOFT 违规转 advisory(如 DURATION_OUT_OF_RANGE→SHORTER_THAN_REQUESTED、OVER_BUDGET)"| C9_ADVISORY
  EXIT_AUDIT --> C9_ADVISORY
  C9_ADVISORY --> C6_NARRATE

  C7_PACKER -->|"render_text()"| ROUTER_BRAIN
  C7_PACKER -->|"render_demand_recap()——版本志+台账生效条目"| W2_REFINE
  C7_PACKER -->|"plan_version_log 切片→'这版是照哪条反馈调的'回顾句"| C6_NARRATE

  C1_SEARCH -->|"relaxed_tags(本次丢了哪些 tag)"| SSE_DEBUG
  SSE_DEBUG -.-> NOTE_RELAX

  subgraph GAPS["ADR-0014 仍然成立的断链(仅剩 2 项,均归 E-3;原九项里的另外七项——出处/硬软分层/<br/>relaxed_tags/预算槽位/physical 复核/gender_mix/pace_profile——已被 G-0~G-4b 收口,<br/>已折叠进上方 CONSUMERS 的实线边,不在此重复罗列)"]
    G_CONF["❌parse_confidence 零消费:prompt 许诺'低置信下游会回问澄清',但无此分支——<br/>G-4b 消费完备性 gate 白名单里唯一挂账的字段<br/>(全仓仅见于 prompt 文案/测试脚本,归 E-3 待接;ambiguous_fields 已有真实消费方,见 C6_NARRATE 边,不再算断链)"]
    G_GLOBAL["❌台账'全局诉求'形态零写手:node_ref=None 从未被任何写手产出——读侧逻辑早就支持<br/>(demand_ledger.py/context/packer.py 的顶替判定与生效切片都能处理全局条目),<br/>但 record_demand 的两个调用点(graph_adjust.py/room.py)一律强制带具体 node_ref<br/>(聊天里说的忌口永远进不了台账面板,归 E-3 待接)"]
  end

  L_INTENT -.->|"parse_confidence 字段"| G_CONF
  L_LEDGER -.->|"node_ref=None 从未出现过"| G_GLOBAL
  W4_SNIFFER -.->|"嗅到的软约束若成为诉求,理应也记台账全局条目,但无此写手"| G_GLOBAL
