stateDiagram-v2

    state "已创建:仅房主,owner.ws is None(create_room 初始化)" as CREATED
    state "有人在线:至少一个成员 ws 非 None,平常协商态" as ONLINE
    state "规划中:room.planning_task 存在且未完成(全量重排/全新规划)" as PLANNING
    state "已确认下单:room.confirmed = True(execute_finalize 真正跑完才置位)" as CONFIRMED
    state "全员离线:成员对象保留,台账等房间状态都还在,只是无人连着" as OFFLINE
