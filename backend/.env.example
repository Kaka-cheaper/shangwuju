# ============================================================
# 晌午局 backend 环境变量样例
# 复制本文件为 .env 后填入真实值；.env 已被 .gitignore 排除
# ============================================================

# ===== LLM =====
# provider: deepseek | qwen | stub（stub 用于前端联调，无需 API key）
LLM_PROVIDER=stub
LLM_TIMEOUT_S=30
LLM_MAX_RETRIES=2

# DeepSeek（主）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 通义（备）
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# ===== 服务 =====
SHANGWUJU_PORT=8000
SHANGWUJU_CORS_ORIGINS=http://localhost:3000

# ===== Planner 范式（Phase 0.6） =====
# rule: 规则化 ReAct（默认；MVP-1/2 主路径，Demo 安全网）
# llm:  LLM Function Calling 自主决策（评分项 2 加分点）
# 单次请求可被 header X-Planner-Mode 覆盖；非法值回 default
PLANNER_MODE=rule

# ===== Mock 数据目录覆盖（可选）=====
# SHANGWUJU_MOCK_DIR=
