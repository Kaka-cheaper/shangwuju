# ============================================================
# 晌午局 backend 环境变量样例
# 复制本文件为 .env 后填入真实值；.env 已被 .gitignore 排除
# ============================================================

# ============================================================
# LLM 配置（任意 OpenAI 兼容 endpoint 都能直接接入）
# ============================================================
# 三件套：API Key + Base URL + Model
#
# 示例 endpoint（任选其一）：
#   DeepSeek    https://api.deepseek.com/v1                       deepseek-chat
#   通义        https://dashscope.aliyuncs.com/compatible-mode/v1  qwen-plus
#   OpenAI      https://api.openai.com/v1                          gpt-4o-mini
#   智谱 GLM    https://open.bigmodel.cn/api/paas/v4               glm-4-plus
#   月之暗面    https://api.moonshot.cn/v1                         moonshot-v1-8k
#   Ollama      http://localhost:11434/v1                          llama3.2
#   LM Studio   http://localhost:1234/v1                           （任意已加载模型）

LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# 可选：provider 展示名（仅日志/UI 用）；缺省时按 base_url 自动推断
# LLM_PROVIDER=

# 全局参数
LLM_TIMEOUT_S=30
LLM_MAX_RETRIES=2

# 开发/单测专用：不调真 LLM，返固定 fixture
# LLM_PROVIDER=stub

# ============================================================
# Planner 模式（Phase 0.6 双范式）
# ============================================================
# rule  规则化 ReAct（默认，Demo 安全网，Tool 调用顺序写死）
# llm   LLM Function Calling 自主决策（评分项 2 加分点）
# 优先级：HTTP header X-Planner-Mode > 此环境变量 > 默认 rule
PLANNER_MODE=rule

# ============================================================
# mode=llm 内部策略（Phase 0.10.3 LLM-First Planner / Phase 0.9 A+C 混合）
# ============================================================
# llm_first        ：LLM-First Planner（默认推荐；产品级架构）
#                    LLM 出蓝图（段集合/顺序/时长/target_id 全开放）+ critic 验证 + backprompt 重试
#                    论文支撑：LLM-Modulo (Kambhampati NeurIPS 2024) + ItiNera (EMNLP 2024)
# hybrid           ：A+C 混合：ILS 启发式 + Critic 验证 + LLM 出权重
#                    论文支撑：TOPTW + ILS（Vansteenwegen 2009）+ LLM-Modulo
# function_calling ：纯 LLM Function Calling 自主调 Tool（旧实现，调用密集）
# fallback 链：llm_first → hybrid → rule（任一层失败自动降级，保 demo 兜底）
PLANNER_LLM_STRATEGY=llm_first

# A+C 混合范式参数（hybrid 子策略用；llm_first 不读这些）
PLANNER_ILS_ITERATIONS=30
PLANNER_CANDIDATE_TOP_K=5
PLANNER_ILS_SEED=20260517

# LLM-First 蓝图 critic backprompt 重试次数（含首次共 N+1 次蓝图机会）
PLANNER_LLM_FIRST_RETRIES=2

# 是否在 main.py 启用真 planner 链路：
# - 默认（不设）：LLM_PROVIDER=stub 时走 _stub_stream（固定 fixture）；其他情况走真 planner
# - 显式设 1   ：强制走真 planner（即使 LLM_PROVIDER=stub 也走真链路 + stub 客户端）
# - 显式设 0   ：强制走 _stub_stream
# PLANNER_USE_REAL=

# ============================================================
# 服务
# ============================================================
SHANGWUJU_PORT=8000
SHANGWUJU_CORS_ORIGINS=http://localhost:3000

# ============================================================
# Mock 数据目录覆盖（可选）
# ============================================================
# SHANGWUJU_MOCK_DIR=

# ============================================================
# 向后兼容（旧 .env 仍生效；新项目不需要填，留作迁移期参考）
# ============================================================
# 仅当 LLM_PROVIDER=deepseek 且 LLM_API_KEY/LLM_BASE_URL/LLM_MODEL 未填时使用：
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat
# 仅当 LLM_PROVIDER=qwen 时使用：
# QWEN_API_KEY=
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL=qwen-plus

# ============================================================
# 会话持久化（Phase 0.11 抽象层）
# ============================================================
# memory ：单进程 dict（demo 默认；进程重启即清，不跨实例）
# redis  ：多实例共享 + 跨设备同步（Milestone 2 stub，切到此值会抛友好提示）
# 演进路径：memory（Demo） → redis（MVP） → postgres（真产品 + analytics）
SESSION_STORE=memory

# ============================================================
# 数据源切换（Phase 0.11 抽象层）
# ============================================================
# 让评委看到「商业演进路径」：业务代码不变，只换数据源。
#
# mock     ：走 backend/tools/ + mock_data/（demo 默认）
# gaode    ：高德 Web Service POI 搜索（Milestone 2，stub）
# dianping ：大众点评开放 API（Milestone 3，stub）
DATA_PROVIDER=mock

# ============================================================
# 日志格式
# ============================================================
# text  ：开发友好（彩色文本）
# json  ：生产格式（接 Sentry / Logfire / Loki）
LOG_FORMAT=text

# ============================================================
# ReAct 单一 Agent feature flag（Phase 0.12）
# ============================================================
# 1（默认）：/chat/turn 走 v2 ReAct 单一 Agent，LLM 自主决策 8 工具
# 0       ：走旧 router → planner / refiner 路径（demo 安全兜底）
# 任何 ReAct 路径异常会自动 fallback 到旧路径，不影响 demo 稳定性
USE_REACT_AGENT=1

# ============================================================
# LangGraph Plan-and-Execute feature flag（v1.0 业界标配）
# ============================================================
# 1     ：/chat/turn 优先走 LangGraph 主架构（router→intent/refiner→并行 execute→
#         planner→assemble→critic→[replan_router→llm_backprompt|ils_replan]→narrate）
# 0（默认）：跳过 LangGraph，走 USE_REACT_AGENT 路径
# 任何 LangGraph 异常会自动 fallback 到 USE_REACT_AGENT 路径
# 三层 fallback 链：LangGraph → ReAct → rule planner（demo 永不翻车）
USE_LANGGRAPH=0


# ============================================================
# 高德地图 Web 服务 Key（Phase 0.13 地理编码 / 路线规划用）
# ============================================================
# 仅给 backend/scripts/enrich_mock_coords.py 等服务端脚本调用
# 申请：https://lbs.amap.com/ → 创建应用 → 添加 Key（平台选「Web 服务」）
# 前端 JS API Key 请单独申请「Web 端(JS API)」，放 frontend/.env.local
AMAP_REST_KEY=

# 高德 JS API 安全密钥（与 frontend/.env.local 的 NEXT_PUBLIC_AMAP_KEY 配对）
# 注：高德 2.0 改版后 JS API 加载强制要求 jscode；但 jscode 不能暴露在前端
# → 通过后端 /_AMapService 代理注入，浏览器永远看不到这个值
# 申请：https://console.amap.com/dev/key/app → 你的应用 → 安全密钥
AMAP_JS_CODE=

